<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <section name="log4net" type="System.Configuration.IgnoreSectionHandler" />
  </configSections>

  <!-- CWE-798: hardcoded credentials / secrets committed to source control -->
  <connectionStrings>
    <add name="AikidoDb"
         connectionString="Data Source=SQL01;Initial Catalog=AikidoTestDb;User ID=sa;Password=P@ssw0rd123!;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />

    <!-- CWE-798: hardcoded API keys / secrets -->
    <add key="StripeApiKey" value="sk_live_51H8x2qKZ9Tg7d6f4NB3mYqQeWJ0placeholderLIVEKEY" />
    <add key="AwsSecretAccessKey" value="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY" />
    <add key="CardEncryptionKey" value="8Bytes1!" />
    <add key="AdminBackdoorPassword" value="letmein2024" />
  </appSettings>

  <system.web>
    <!-- CWE-489 / CWE-215: debug compilation and verbose errors left on in a "production" config -->
    <compilation debug="true" targetFramework="4.7.2" />

    <!-- CWE-209: detailed exception/stack trace information disclosed to remote users -->
    <customErrors mode="Off" />

    <!-- CWE-16: request validation disabled at the application level, removing built-in reflected-XSS protection -->
    <httpRuntime targetFramework="4.7.2" requestValidationMode="2.0" maxRequestLength="204800" />
    <pages validateRequest="false" />

    <!-- CWE-614 / CWE-1004: session cookie missing Secure and HttpOnly hardening, long timeout -->
    <sessionState cookieless="false" timeout="240" cookieName="ASP.NET_SessionId" />
    <httpCookies httpOnlyCookies="false" requireSSL="false" />

    <authentication mode="Forms">
      <forms loginUrl="~/Account/Login" timeout="240" protection="None" requireSSL="false" />
    </authentication>

    <!-- CWE-321: hardcoded, weak machineKey used for viewstate/forms-auth ticket protection -->
    <machineKey validationKey="1122334455667788990011223344556677889900112233445566778899"
                decryptionKey="AABBCCDDEEFF00112233445566778899AABBCCDDEEFF00"
                validation="SHA1" decryption="DES" />

    <trace enabled="true" localOnly="false" />
  </system.web>

  <system.webServer>
    <!-- CWE-942: overly permissive CORS policy -->
    <httpProtocol>
      <customHeaders>
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Headers" value="*" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE" />
        <!-- CWE-200: technology fingerprinting headers left enabled -->
        <add name="X-Powered-By" value="ASP.NET" />
      </customHeaders>
    </httpProtocol>
    <directoryBrowse enabled="true" />
    <modules runAllManagedModulesForAllRequests="true" />
  </system.webServer>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm-v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.4.0" newVersion="6.0.4.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
